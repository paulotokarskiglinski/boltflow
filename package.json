{
  "name": "boltflow",
  "version": "1.0.0",
  "author": "paulotokarskiglinski",
  "license": "MIT",
  "description": "Boltflow is a developer tool that generates interactive, self-contained visualizations of your application's component architecture",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulotokarskiglinski/boltflow"
  },
  "homepage": "https://github.com/paulotokarskiglinski/boltflow#readme",
  "bugs": {
    "url": "https://github.com/paulotokarskiglinski/boltflow/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "boltflow": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/copy-assets.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "angular",
    "visualization",
    "components",
    "flow",
    "flowchart",
    "architecture",
    "diagram",
    "graph",
    "devtools",
    "markdown"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "node-html-parser": "^6.1.13",
    "open": "^8.4.2",
    "ora": "^5.4.1",
    "ts-morph": "^22.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
